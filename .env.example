# ============================================
# Deriv AI Innovation Marketplace - Environment Variables
# Copy this file to .env and fill in your real values.
# ============================================

# OpenAI / LiteLLM API Credentials
OPENAI_API_KEY=sk-your-api-key-here

# LiteLLM Proxy Configuration
API_BASE_URL=https://your-litellm-proxy-url/v1
OPENAI_MODEL_NAME=your-model-name

# Firebase Configuration
# Set to true to connect to real Firebase Firestore, or false to use Mock DB locally
NEXT_PUBLIC_USE_FIREBASE=false
NEXT_PUBLIC_FIREBASE_API_KEY=your-firebase-api-key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=000000000000
NEXT_PUBLIC_FIREBASE_APP_ID=1:000000000000:web:0000000000000000000000

# Optional: Deriv Brain integration
# DERIV_BRAIN_API_KEY=your-brain-api-key
# DERIV_BRAIN_WEBHOOK_SECRET=your-brain-webhook-secret