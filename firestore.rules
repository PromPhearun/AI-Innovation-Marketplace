rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Users Collection
    match /users/{userId} {
      allow read, write: if true;
    }

    // Ideas Collection
    match /ideas/{ideaId} {
      allow read, write: if true;
    }

    // Reviews Collection
    match /reviews/{reviewId} {
      allow read, write: if true;
    }

    // Votes Collection
    match /votes/{voteId} {
      allow read, write: if true;
    }

    // Comments Collection
    match /comments/{commentId} {
      allow read, write: if true;
    }

    // Summaries Collection
    match /summaries/{ideaId} {
      allow read, write: if true;
    }
  }
}
